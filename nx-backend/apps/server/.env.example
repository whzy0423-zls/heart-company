PORT=5320
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=123456
SITE_CONFIG_PATH=../../../shared/site-config.json

# PostgreSQL 连接串（本地开发示例；容器内由 compose 注入）
DATABASE_URL=postgres://nx:nx@localhost:5432/nx_admin?sslmode=disable

# 保存官网配置后自动重新构建并发布 website-react。
# 留空则关闭自动构建（仅写 JSON，不触发构建）。
BUILD_SCRIPT=../../scripts/build-website.sh
BUILD_TIMEOUT_SECONDS=600
# build-website.sh 读取的发布目标（nginx root）；按需覆盖：
# WEBSITE_PUBLISH_DIR=/usr/share/nginx/html
# WEBSITE_DIR=../../../website-react
