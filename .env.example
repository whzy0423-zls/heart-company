# ── 生产环境变量（docker compose 自动读取本文件）──
# 复制本文件为 .env 并填入真实值：cp .env.example .env

# JWT 签名密钥：务必换成强随机串
#   生成：openssl rand -hex 32
JWT_SECRET=please-change-me-to-a-long-random-secret

# 后台管理员账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# PostgreSQL（docker compose 内置 db 服务使用）
POSTGRES_USER=nx
POSTGRES_PASSWORD=change-me-too
POSTGRES_DB=nx_admin

# 阿里云 OSS 文件上传
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
# 示例：oss-cn-hangzhou.aliyuncs.com
OSS_ENDPOINT=
# 示例：cn-hangzhou
OSS_REGION=
# 可选：CDN 或 bucket 公网访问域名，例如 https://cdn.example.com
OSS_PUBLIC_URL=
OSS_PREFIX=uploads
UPLOAD_MAX_MB=20

# MiniMax 中文版：人声克隆/文本转语音
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_API_BASE=https://api.minimaxi.com

# 微信小程序登录（留空则启用 dev 登录回退，无需真实凭证即可本地联调）
WECHAT_APPID=
WECHAT_SECRET=

# 微信支付 v3（JSAPI）。任一关键项缺失即启用 dev 模拟支付（下单返回伪参数，
# 前端会直接通知后端「支付成功」走通解锁闭环）。上线务必配齐：
WXPAY_MCH_ID=
WXPAY_APPID=
WXPAY_API_V3_KEY=
WXPAY_SERIAL_NO=
WXPAY_PRIVATE_KEY_PATH=
WXPAY_NOTIFY_URL=
# 深度报告单价（分），默认 990 = ￥9.9
WXPAY_REPORT_PRICE_CENTS=990

# 向量检索（RAG 语义召回）。Provider 为空则关闭向量化，回退关键词检索。
# 兼容 OpenAI 风格 /v1/embeddings。维度需与数据库 vector(N) 一致（默认 1536）。
EMBEDDING_PROVIDER=
EMBEDDING_API_BASE=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
EMBEDDING_DIMENSION=1536
